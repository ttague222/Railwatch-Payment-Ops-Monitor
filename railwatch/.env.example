# RailWatch API Keys
# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — never commit real keys.

# FRED API — Federal Reserve Economic Data
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# DEMO_KEY works for testing but is rate-limited to 120 requests/day per IP.
VITE_FRED_API_KEY=DEMO_KEY

# Marketaux — Financial News API
# Free tier: 100 requests/month — https://www.marketaux.com/
# Sign up at https://app.marketaux.com/register to get your token.
VITE_MARKETAUX_API_TOKEN=

# Frankfurter (FX rates) — no key required, open API.
